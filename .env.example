# spirit loop 用 .env.local のフォーマット例
# このファイルをコピーして .env.local を作成し、各値を設定してください

# OPENAI_API_KEYを環境変数として設定してください
OPENAI_API_KEY=

# Cloudflare Worker のデプロイ先URL
WORKER_URL=

# Worker と spirit loop で共有するシークレット（任意の文字列）
SPIRIT_SECRET=

# Discord Bot トークン
DISCORD_BOT_TOKEN=

# Discord メッセージ送信先チャンネル ID
DISCORD_CHANNEL_ID=
